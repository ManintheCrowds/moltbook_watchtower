# Moltbook Watchtower — example environment (copy to .env, never commit .env)
# API key: single "watchdog" agent registered on Moltbook; used for read-only GETs only.
# CRITICAL: This key is sent ONLY to https://www.moltbook.com — never elsewhere.
MOLTBOOK_API_KEY=your_watchdog_agent_key

# Optional: alerting (leave empty to disable)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_EMAIL=

# Optional: jitter for cron (seconds, 0=off). e.g. 60 = random 0-60s delay at start
# JITTER_SECONDS=60

# Optional: paths (defaults used if unset)
# DATA_DIR=data
# LOG_DIR=logs

# Optional: daily report in repo (e.g. reports/daily → reports/daily/YYYY-MM-DD.md)
# DAILY_REPORT_DIR=reports/daily
# REPORT_DATE=2025-02-02

# Optional: max posts to fetch comments for per collector run (1–50, default 25)
# COMMENT_FETCH_LIMIT=25

# Optional: Signal alerting (see docs/runbooks/signal-alerting.md)
# SIGNAL_ENABLED=0
# SIGNAL_RECIPIENT=
# SIGNAL_MESSAGE_PREFIX=[Watchtower]
